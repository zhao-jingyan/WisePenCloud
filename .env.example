# =============================================================================
# .env 样例
# -----------------------------------------------------------------------------
# 此 env 为 Spring Cloud bootstrap 阶段（连 Nacos 之前）必须就位的最小环境变量集合
# 业务字段由 Nacos 配置中心注入
#
# 用法：
#   cp .env.example .env
#   按需修改相关变量
# =============================================================================

# Nacos 接入
NACOS_SERVER_ADDR=localhost:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# Spring profile
# 本机起服务保持 dev，容器/Jenkins 部署时由 docker compose 直接覆盖为 prod
SPRING_PROFILES_ACTIVE=dev

# OpenTelemetry Java Agent
# 本机开发默认关闭遥测
# 如需开启本机遥测，按实际 Collector 协议二选一：
#   1) OTLP/gRPC：使用 4317，并设置 OTEL_EXPORTER_OTLP_PROTOCOL=grpc
#   2) OTLP/HTTP：使用 4318，并设置 OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SDK_DISABLED=true
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# 注册到 Nacos 时的本机 IP（可选）
# 留空时由 spring-cloud-commons 按 inetutils 偏好自动选择，容器 / 多网卡场景下显式指定更稳。
# SPRING_CLOUD_INETUTILS_DEFAULT_IP_ADDRESS=127.0.0.1
